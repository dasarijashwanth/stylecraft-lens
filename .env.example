# ==============================================================================
# STYLECRAFT LENS ENVIRONMENT CONFIGURATION (.env.example)
# ==============================================================================

# Google Gemini API Key (powers competitive research, market analysis, sales-kit/TDS
# generation, artwork vision analysis, and report rewriting — with built-in Google
# Search grounding, so no separate Google Custom Search key is needed)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key"

# Rainforest API Key (for real-time Amazon pricing, ratings, reviews & BSR lookup)
# Sign up / get key at: https://trajectdata.com/discover-rainforest-api/
RAINFOREST_API_KEY="your_rainforest_api_key"

# Database / PostgreSQL Connection String (Optional - falls back to memoryDb if unconfigured)
DATABASE_URL="postgresql://user:password@localhost:5432/stylecraft_lens"

# Supabase Storage & Database Configuration (Optional - falls back to memoryDb if unconfigured)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Clerk Authentication Keys (Optional - mock auth enabled if unconfigured)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
