# ==============================================================================
# STYLECRAFT LENS ENVIRONMENT CONFIGURATION (.env.example)
# ==============================================================================

# Google Gemini API Key (powers competitive research, market analysis, sales-kit/TDS
# generation, artwork vision analysis, and report rewriting — with built-in Google
# Search grounding, so no separate Google Custom Search key is needed)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key"

# Rainforest API Key (for real-time Amazon pricing, ratings, reviews & BSR lookup)
# Sign up / get key at: https://trajectdata.com/discover-rainforest-api/
RAINFOREST_API_KEY="your_rainforest_api_key"

# OpenAI API Key (PRIMARY provider for all analysis/synthesis, web
# search/scraping, and review analysis. Get a key at: https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-proj-..."

# Database / PostgreSQL Connection String (Optional - falls back to memoryDb if unconfigured)
DATABASE_URL="postgresql://user:password@localhost:5432/stylecraft_lens"

# Supabase Storage & Database Configuration (Optional - falls back to memoryDb if unconfigured)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Clerk Authentication Keys (Optional - mock auth enabled if unconfigured)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Google Drive Integration (Optional - "Save to Drive" falls back to a mock
# link if unconfigured). All three are required together:
# 1. GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET: from Google Cloud Console ->
#    APIs & Services -> Credentials -> OAuth 2.0 Client IDs (type: Web application)
# 2. GOOGLE_REFRESH_TOKEN: generated once via https://developers.google.com/oauthplayground
#    using the Client ID/Secret above and the Drive API scope
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REFRESH_TOKEN="your_google_refresh_token"
